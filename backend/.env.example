# --- Node / Server ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://beach:beach_secret@localhost:5432/beach_tennis?schema=public

# --- Auth ---
# Generate a strong secret for production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@beachtennis.local

# --- S3-compatible object storage ---
# For Minio (local docker-compose): http://minio:9000
# For AWS S3: leave empty to use the default AWS endpoint
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=beach-tennis
# "true" for Minio, "false" (or unset) for AWS S3
S3_FORCE_PATH_STYLE=true
# Public base URL clients will use to GET uploaded objects
S3_PUBLIC_BASE_URL=http://localhost:9000/beach-tennis
